# Supabase Configuration
# Get these values from your Supabase project settings
# Dashboard > Settings > API

EXPO_PUBLIC_SUPABASE_URL=your-supabase-project-url
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Supabase > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@host:5432/postgres

# Mapbox
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-public-token
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=your-mapbox-secret-download-token

# Third-party APIs (used by scripts/)
GOLF_COURSE_API_KEY=your-golf-course-api-key
GOOGLE_GEOCODING_API_KEY=your-google-geocoding-api-key